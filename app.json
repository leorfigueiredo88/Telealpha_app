{
  "expo": {
    "name": "Telealpha",
    "slug": "telealpha-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "telealpha",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#003366"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.telealpha.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#003366"
      },
      "package": "com.telealpha.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite selecionar fotos da galeria para o perfil e checklist.",
          "cameraPermission": "Permite tirar fotos para o checklist do veículo."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8317b216-2990-4f6b-90c2-c8c14f471f36"
      }
    },
    "owner": "leorf88"
  }
}
